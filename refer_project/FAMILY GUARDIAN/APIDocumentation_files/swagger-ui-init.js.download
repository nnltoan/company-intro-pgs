        "patch": {
          "summary": "Update a security zone",
          "tags": [
            "Security Zones"
          ],
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "parameters": [
            {
              "in": "path",
              "name": "zoneId",
              "required": true,
              "schema": {
                "type": "string"
              },
              "description": "ID of the security zone",
              "example": "zone123"
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "zone_name",
                    "zone_range",
                    "address",
                    "latitude",
                    "longitude",
                    "alert_condition",
                    "member_ids"
                  ],
                  "properties": {
                    "zone_name": {
                      "type": "string",
                      "description": "Name of the security zone",
                      "example": "Home Zone"
                    },
                    "zone_range": {
                      "type": "number",
                      "description": "Radius of the zone in meters (1-1000)",
                      "example": 100
                    },
                    "address": {
                      "type": "string",
                      "description": "Address of the zone",
                      "example": "123 Main St, Hanoi"
                    },
                    "latitude": {
                      "type": "number",
                      "description": "Latitude coordinate (-90 to 90)",
                      "example": 10.7769
                    },
                    "longitude": {
                      "type": "number",
                      "description": "Longitude coordinate (-180 to 180)",
                      "example": 106.7009
                    },
                    "alert_condition": {
                      "$ref": "#/components/schemas/AlertCondition",
                      "description": "Condition for triggering alerts"
                    },
                    "member_ids": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "IDs of members to add to the zone",
                      "example": [
                        "user456",
                        "user789"
                      ]
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Security zone updated successfully",

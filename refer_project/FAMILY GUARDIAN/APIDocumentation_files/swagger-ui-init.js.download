      "/alerts/{zoneId}": {
        "post": {
          "summary": "Create a new alert history entry",
          "tags": [
            "Alerts"
          ],
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "parameters": [
            {
              "in": "path",
              "name": "zoneId",
              "required": true,
              "schema": {
                "type": "string"
              },
              "description": "ID of the security zone",
              "example": "zone123"
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "event",
                    "timestamp"
                  ],
                  "properties": {
                    "event": {
                      "type": "string",
                      "enum": [
                        "entering",
                        "leaving"
                      ],
                      "description": "Type of alert event",
                      "example": "entering"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time",
                      "description": "Timestamp of the alert",
                      "example": "2025-05-15T12:00:00Z"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Alert history created successfully",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse",
                    "properties": {
                      "data": {
                        "$ref": "#/components/schemas/AlertHistoryResponse"
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid input",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              }
            },
            "401": {
              "description": "Unauthorized",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              }
            },
            "403": {
              "description": "Forbidden (e.g., zone is turned off, location sharing disabled, or condition mismatch)",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              }
            },
            "500": {
              "description": "Server error",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              }
            }
          }
        },
        "get": {
          "summary": "Get alert history for a zone",
          "tags": [
            "Alerts"
          ],
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "parameters": [
            {
              "in": "path",
              "name": "zoneId",
              "required": true,
              "schema": {
                "type": "string"
              },
              "description": "ID of the security zone or 'all' for all zones",
              "example": "zone123"
            },
            {
              "in": "query",
              "name": "date",
              "required": true,
              "schema": {
                "type": "string",
                "format": "date-time"
              },
              "description": "Date to filter alert history",
              "example": "2025-05-15T00:00:00Z"
            }
          ],
          "responses": {
            "200": {
              "description": "Alert history retrieved successfully",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse",
                    "properties": {
                      "data": {
                        "type": "array",
                        "items": {
                          "$ref": "#/components/schemas/AlertHistoryResponse"
                        }
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid input",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              }
            },
            "401": {
              "description": "Unauthorized",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              }
            },
            "500": {
              "description": "Server error",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              }
            }
          }
        }
      },
      "/devices": {
        "post": {
          "summary": "Add a new device",
          "tags": [
            "Devices"
          ],
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "device_id",
                    "device_name",
                    "device_type",
                    "device_category",
                    "mac_address",
                    "is_support_play_sound",
                    "current_location"
                  ],
                  "properties": {
                    "device_id": {
                      "type": "string",
                      "description": "Unique ID of the device",
                      "example": "device123"
                    },
                    "device_name": {
                      "type": "string",
                      "description": "Name of the device",
                      "example": "My iPhone"
                    },
                    "device_type": {
                      "type": "string",
                      "enum": [
                        "iPhone",
                        "iPad",
                        "MacBook",
                        "Mac",
                        "airpods",
                        "airpods_pro",
                        "airpods_max",
                        "sony_headphones",
                        "bose_headphones",
                        "jabra_headphones",
                        "sennheiser_headphones",
                        "jbl_speaker",
                        "bose_speaker",
                        "sony_speaker",
                        "marshall_speaker",
                        "ue_boom_speaker",
                        "apple_watch",
                        "garmin",
                        "fitbit",
                        "xiaomi_mi_band",
                        "airtag"
                      ],
                      "description": "Type of the device",
                      "example": "iPhone"
                    },
                    "device_category": {
                      "type": "string",
                      "enum": [
                        "personal",
                        "bluetooth_audio",
                        "wearable",
                        "iot"
                      ],
                      "description": "Category of the device",
                      "example": "personal"
                    },
                    "mac_address": {
                      "type": "string",

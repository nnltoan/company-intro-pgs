                  ],
                  "properties": {
                    "signed_request": {
                      "type": "string",
                      "description": "Signed request from Facebook",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyX2lkIjoiZmIxMjM0NTYifQ.signature"
                    }
                  }
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Deletion callback processed successfully",
              "content": {
                "application/json": {

      "/locations/autocomplete": {
        "get": {
          "summary": "Autocomplete location search using Mapbox",
          "tags": [
            "Locations"
          ],
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "parameters": [
            {
              "in": "query",
              "name": "query",
              "required": true,
              "schema": {
                "type": "string"
              },
              "description": "Search query for location",
              "example": "123 Main St"
            },
            {
              "in": "query",
              "name": "language",
              "required": false,
              "schema": {
                "type": "string"
              },
              "description": "Language for search results",
              "example": "en"
            },
            {
              "in": "query",
              "name": "country",
              "required": false,
              "schema": {
                "type": "string"
              },
              "description": "Country code to filter results",
              "example": "VN"
            },
            {
              "in": "query",
              "name": "proximity",
              "required": false,
              "schema": {
                "type": "object",
                "properties": {
                  "longitude": {
                    "type": "number",
                    "example": 106.7009
                  },
                  "latitude": {
                    "type": "number",
                    "example": 10.7769
                  }
                }
              },
              "description": "Coordinates to prioritize results near a location"
            }
          ],
          "responses": {
            "200": {
              "description": "Autocomplete results retrieved successfully",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse",
                    "properties": {
                      "data": {
                        "type": "array",
                        "items": {
                          "$ref": "#/components/schemas/AutocompleteResponse"
                        }
                      }
                    }
                  }
                }
              }
            },
            "400": {
              "description": "Invalid query or proximity format",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              }
            },
            "401": {
              "description": "Unauthorized",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              }
            },
            "500": {
              "description": "Server error",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              }
            }
          }
        }
      },
